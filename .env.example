# --- MongoDB Memory (messages + facts) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=agent_memory

# --- Redis (blackboard hot store) ---
# Leave unset to disable Redis mirroring (Orchestrator still keeps the in-memory blackboard).
# REDIS_URL=redis://localhost:6379/0

# --- Postgres (durable commit store) ---
# Leave unset to disable durable commits. Tables auto-created on startup.
# POSTGRES_DSN=postgresql://user:pass@localhost:5432/agent_commits

# --- MCP ---
# URL of the MCP server to connect to. Leave empty to disable MCP tool loading.
MCP_SERVER_URL=http://localhost:8001/mcp
# Logical name for the server (used internally as the client key)
MCP_SERVER_NAME=default
# Transport protocol: sse | stdio | websocket | streamable_http
MCP_TRANSPORT=streamable_http
# Bearer token for the Authorization header. Leave empty if the server is unauthenticated.
MCP_AUTH_TOKEN=
# Request timeout in seconds (default: 30.0)
MCP_TIMEOUT=30.0

# --- LLM (OpenAI / OpenAI-compatible) ---
# Required: OpenAI API key (or compatible provider key)
OPENAI_API_KEY=sk-...
# Model name. Defaults to gpt-4o-mini. Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini
# Optional: override the base URL for OpenAI-compatible endpoints (Azure, Together, Groq, local LLMs, etc.).
# Leave unset to use the default OpenAI API endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Observability (MLflow) ---
# Remote MLflow tracking server. Required for traces to be persisted.
# Without this, the app starts but tracing is a no-op (warning logged at startup).
MLFLOW_TRACKING_URI=https://your-mlflow-server.example.com
MLFLOW_EXPERIMENT_NAME=base-agent-framework
