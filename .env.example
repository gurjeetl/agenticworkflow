# --- MongoDB Memory (messages + facts) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=agent_memory

# --- Redis (blackboard hot store) ---
# Mirrors every blackboard entry to Redis (key bb:{thread_id}:{run_id}:{task_id}, 24h TTL)
# and powers GET /blackboard/{thread_id}/{run_id}. To enable: `pip install redis`, run a
# Redis server, then set REDIS_URL below. Leave unset to disable (the in-memory blackboard
# still works — mirroring simply no-ops).
# REDIS_URL=redis://localhost:6379/0

# --- MongoDB durable commit store ---
# Durable agent-output commits (collection agent_commits) + entity links live in
# the same MongoDB as messages/facts above (MONGODB_URI / MONGODB_DB). Always on —
# MongoDB is the framework's primary datastore. No separate config needed.

# --- Milvus (semantic long-term memory / vector store) ---
# Planner recalls relevant past memories and the Synthesizer writes an embedding of
# each answer to the `long_term_memory` collection. Leave MILVUS_URI unset to disable
# (search returns nothing, writes no-op — the app still runs).
#
# Easiest: local Milvus Lite file — no server/Docker, works on Windows too. Point
# MILVUS_DB_PATH at a local .db path (the [milvus_lite] extra in requirements.txt ships it).
# NOTE: use MILVUS_DB_PATH (not MILVUS_URI) for a file — pymilvus reserves MILVUS_URI for
# http endpoints and validates it at import, so a file path there crashes the import.
MILVUS_DB_PATH=./milvus_local.db
# Or a remote/standalone server (Docker) — use MILVUS_URI with an http URL:
#   docker run -d --name milvus -p 19530:19530 milvusdb/milvus:latest milvus run standalone
#   MILVUS_URI=http://localhost:19530
# MILVUS_TOKEN=
# MILVUS_COLLECTION=long_term_memory
# Embedding model + dimension (OpenAI-compatible; uses OPENAI_API_KEY / OPENAI_BASE_URL below).
OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_EMBED_DIM=1536

# --- Registry / Discovery Service ---
# Base URL the Planner/Executor and agent services use to reach the registry.
REGISTRY_URL=http://127.0.0.1:8002
# Port the registry service binds to (python -m registry.service).
REGISTRY_PORT=8002
# Optional bearer token. When set, all registry endpoints except /health require it.
REGISTRY_AUTH_TOKEN=
# Liveness window: a record expires if it hasn't heartbeat within this many seconds.
REGISTRY_TTL_SECONDS=90
# How often each agent heartbeats (≈ TTL/3 is a good default).
REGISTRY_HEARTBEAT_SECONDS=30
# In-process cache TTL for the Planner/Executor registry client (seconds).
REGISTRY_CACHE_TTL_S=5
# httpx timeout for registry lookups (seconds).
REGISTRY_TIMEOUT_S=3
# Serve the last good cached agent list if a refresh fails (1=yes).
REGISTRY_SERVE_STALE=1

# --- Agent service (per agent process; see scripts/run-all.ps1) ---
# Bind host/port for an agent service. Each agent runs on its own port (e.g. 8010, 8011).
AGENT_HOST=127.0.0.1
AGENT_PORT=8010
# Host/port advertised to the registry as this agent's endpoint. Override in
# containers/remote deploys where the bind address differs from the routable one.
# AGENT_ADVERTISE_HOST=127.0.0.1
# AGENT_ADVERTISE_PORT=8010
# Optional bearer token the Executor must present to call POST /invoke.
# AGENT_INVOKE_TOKEN=

# --- MCP ---
# URL of the MCP server to connect to. Leave empty to disable MCP tool loading.
MCP_SERVER_URL=http://localhost:8001/mcp
# Logical name for the server (used internally as the client key)
MCP_SERVER_NAME=default
# Transport protocol: sse | stdio | websocket | streamable_http
MCP_TRANSPORT=streamable_http
# Bearer token for the Authorization header. Leave empty if the server is unauthenticated.
MCP_AUTH_TOKEN=
# Request timeout in seconds (default: 30.0)
MCP_TIMEOUT=30.0

# --- LLM (OpenAI / OpenAI-compatible) ---
# Required: OpenAI API key (or compatible provider key)
OPENAI_API_KEY=sk-...
# Model name. Defaults to gpt-4o-mini. Examples: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini
# Optional sampling temperature applied to ALL LLM calls (router, planner, agents,
# synthesizer). Set 0 for deterministic routing/planning/synthesis — this reduces
# run-to-run path variance (a prompt fast-pathing one run, full-planning the next)
# and the spurious re-plans that variance triggers. Unset = provider default (~1.0).
# OPENAI_TEMPERATURE=0
# Optional faster/cheaper model JUST for the Planner — the single heaviest LLM call
# (big agent-menu prompt + a generated DAG). Falls back to OPENAI_MODEL. Mirrors ROUTER_MODEL.
# PLANNER_MODEL=gpt-4o-mini
# Optional faster/cheaper model JUST for the Synthesizer — the multi-task merge call
# (reads the whole blackboard incl. view payloads). Falls back to OPENAI_MODEL.
# SYNTHESIZER_MODEL=gpt-4o-mini
# Max recalled facts injected into the planner prompt. The facts block is the
# dynamic (un-cached) part of the prompt and grows as a session accumulates facts,
# so this bounds planner latency drift over long conversations. Default 40.
# PLANNER_MAX_FACTS=40
# Optional: override the base URL for OpenAI-compatible endpoints (Azure, Together, Groq, local LLMs, etc.).
# Leave unset to use the default OpenAI API endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Router (intent triage in front of the Planner) ---
# Optional cheaper/faster model just for routing (falls back to OPENAI_MODEL).
# ROUTER_MODEL=gpt-4o-mini
# Min confidence for the router to commit to a single-agent "fast" path.
# ROUTER_MIN_CONFIDENCE=0.7
# Local multi-intent classifier: skips the router LLM call when a prompt clearly
# activates 2+ agents (embedding similarity). 1=on (default), 0=regex-only.
# ROUTER_INTENT_CLASSIFIER=1
# ROUTER_INTENT_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Cosine >= this counts an agent as "activated" (calibrated ~0.30 for bundled agents).
# ROUTER_INTENT_THRESHOLD=0.30
# Activated-agent count at/above which a prompt is treated as multi-intent.
# ROUTER_INTENT_MIN_AGENTS=2
# Regex (additive connectors) that also forces the multi-intent path.
# ROUTER_MULTI_INTENT_PATTERN=

# --- LLM Guard (MANDATORY content guard; local models, always on) ---
# There is NO enable/disable flag — the guard always runs and the app fails to
# start if the library/models can't load (fail-closed). These tune it:
# Comma-separated topics the ban-topics scanner blocks (defaults to a built-in list).
# PERF: each topic is a separate zero-shot NLI forward pass on BOTH the input and
# output guard, so fewer topics = faster guards. Trim to what you actually need.
# LLM_GUARD_BAN_TOPICS=violence,self-harm,hate speech,illegal weapons
# PII/secret redaction scanners (Anonymize/Secrets on input, Sensitive on output).
# 1=on (default). Set 0 to drop them when the app handles no personal data — removes
# a heavyweight NER forward pass from BOTH guards. Does NOT affect the blocking
# scanners (injection/toxicity/banned-topics/regex stay on). LLM_GUARD_PII=0
# LLM_GUARD_PII=1
# Deterministic code/script-injection patterns (XSS/SQLi/shell/template/path-traversal)
# the Regex scanner blocks. NEWLINE-delimited (regexes contain commas) and REPLACES the
# built-in defaults when set. Leave unset to use the built-in list. Example:
# LLM_GUARD_INJECTION_PATTERNS="(?i)<\s*script\b
# (?i)\$\{\s*jndi:
# (?:\.\.[\\/]){2,}"
# On a scanner RUNTIME error: 0 = fail-closed (block, default), 1 = fail-open (allow).
# LLM_GUARD_FAIL_OPEN=0
# Backend for the guard's ML scanners. 0 = PyTorch (default, faster here), 1 = ONNX.
# ONNX only helps with INT8-quantized models; llm-guard's default ONNX exports are
# NOT quantized and benchmarked ~3x slower on CPU, so leave this off unless you supply
# quantized models. Enabling it needs: pip install "llm-guard[onnxruntime]".
# LLM_GUARD_USE_ONNX=0
# Run the read-only scanners concurrently instead of sequentially (1=on default, 0=off).
# Marginal on CPU (the ML scanners already saturate all cores), kept as a safe fallback.
# LLM_GUARD_PARALLEL=1
# EXPERIMENTAL — use locally-built INT8 ONNX classifiers (scripts/quantize_guard_models.py).
# Benchmarked WORSE here (security/bench_guard.py): ~3x slower AND it regressed prompt-injection
# detection. Off by default; do not enable without re-running bench_guard. 0=off (default), 1=on.
# LLM_GUARD_ONNX_QUANTIZED=0

# --- Local model CPU threads ---
# Cap PyTorch intra-op threads for the local models (LLM Guard + router classifier).
# Helps only under CONCURRENT load (overlapping inferences otherwise oversubscribe cores
# and slow each other). Unset = PyTorch default. Try ~half your physical cores under load.
# TORCH_NUM_THREADS=4

# --- Observability (MLflow) ---
# Remote MLflow tracking server. Required for traces to be persisted.
# Without this, the app starts but tracing is a no-op (warning logged at startup).
MLFLOW_TRACKING_URI=https://your-mlflow-server.example.com
MLFLOW_EXPERIMENT_NAME=base-agent-framework
